# Copy this file to .env and fill in your own values.
# Never commit the real .env file — it's already excluded in .gitignore.

# Google Sheets
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Gemini API (used by the HTTP Request node for company research + outreach generation)
GEMINI_API_KEY=your_gemini_api_key_here

# SMTP (used by the Send an Email node)
SMTP_FROM_EMAIL=outreach@yourcompany.com

# n8n instance (only needed if you're self-hosting / scripting deployment)
N8N_INSTANCE_URL=https://your-n8n-instance.example.com
