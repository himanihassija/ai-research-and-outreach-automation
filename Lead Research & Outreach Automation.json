        "mode": "runOnceForEachItem",
        "jsCode": "const html = $json.data || '';\n\nconst cleaned = html\n  .replace(/<script[\\s\\S]*?<\\/script>/gi, '')\n  .replace(/<style[\\s\\S]*?<\\/style>/gi, '')\n  .replace(/<[^>]+>/g, ' ')\n  .replace(/\\s+/g, ' ')\n  .trim();\n\nreturn {\n  website_text: cleaned.slice(0, 800)\n};"
